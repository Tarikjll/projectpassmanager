@page
@model PersonalDataModel
@{
    ViewData["Title"] = T("Account.PersonalData");
    ViewData["ActivePage"] = ManageNavPages.PersonalData;
}

<div class="page-shell">
    <div class="form-card-header">
        <span class="home-kicker">@T("Account.ProfileKicker")</span>
        <h2>@T("Account.PersonalData")</h2>
        <p class="page-subtitle">
            Your account contains personal data that you have given us. This page allows you to download or delete that data.
        </p>
    </div>

    <div class="content-card">
        <div class="content-card-body">
            <p class="mb-4 fw-semibold">
                Deleting this data will permanently remove your account, and cannot be recovered.
            </p>

            <div class="personal-data-actions">
                <form method="post" asp-page-handler="DownloadPersonalData">
                    <button type="submit" class="btn btn-lg btn-primary">
                        @T("Account.DownloadPersonalData")
                    </button>
                </form>

                <form method="post"
                      asp-page-handler="DeletePersonalData"
                      onsubmit="return confirm('Are you sure you want to delete your account?');">
                    <button type="submit" class="btn btn-lg btn-outline-danger">
                        @T("Common.Delete")
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
