@model BAD_PROJECT_PWMANAGER.ViewModels.PasswordEntry.PasswordEntryFormViewModel

@{
    ViewData["Title"] = T("Password.CreateTitle");
}

<div class="page-shell">
    <div class="page-header">
        <div>
            <h1>@T("Password.CreateTitle")</h1>
            <p class="page-subtitle">@T("Password.CreateSubtitle")</p>
        </div>
    </div>

    <form asp-action="Create" method="post" class="form-panel">
        @Html.AntiForgeryToken()

        <input type="hidden" asp-for="VaultId" />

        <div asp-validation-summary="All" class="text-danger form-summary"></div>

        <div class="form-grid">
        <div class="form-group form-field full-width">
            <label asp-for="Platform" class="form-label">@T("Password.PlatformWebsite")</label>
            <input asp-for="Platform" class="form-control form-control-lg" />
            <span asp-validation-for="Platform" class="text-danger"></span>
        </div>

        <div class="form-group form-field">
            <label asp-for="Username" class="form-label">@T("Password.UsernameEmail")</label>
            <input asp-for="Username" class="form-control" />
            <span asp-validation-for="Username" class="text-danger"></span>
        </div>

        <div class="form-group form-field">
            <label asp-for="Url" class="form-label">@T("Password.Url")</label>
            <input asp-for="Url" class="form-control" placeholder="https://example.com" />
            <span asp-validation-for="Url" class="text-danger"></span>
        </div>

        <div class="form-group form-field full-width">
            <label asp-for="PlainPassword" class="form-label">@T("Account.Password")</label>
            <input asp-for="PlainPassword" class="form-control" />
            <span asp-validation-for="PlainPassword" class="text-danger"></span>
        </div>

        <div class="form-group form-field full-width">
            <label asp-for="Notes" class="form-label">@T("Password.Notes")</label>
            <textarea asp-for="Notes" class="form-control" rows="4"></textarea>
            <span asp-validation-for="Notes" class="text-danger"></span>
        </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">@T("Common.Save")</button>
            <a asp-action="Index" asp-route-vaultId="@Model.VaultId" class="btn btn-outline-secondary">@T("Common.Cancel")</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
